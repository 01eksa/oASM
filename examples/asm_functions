section .data
    arr = [1, 2, 3]
    str = "123\0"

    arr_msg     = "[1, 2, 3]\n\0"
    str_msg     = "\"123\\0\"\n\0"
    sizeof_msg  = "size: \0"
    lenof_msg   = "len: \0"

section .code
    mov     fr,     1
    lea     arg1,   arr_msg
    vmcall

    lea     arg1,   sizeof_msg
    vmcall
    push    sizeof(arr)
    printint
    printendl

    lea     arg1,   lenof_msg
    vmcall
    push    lenof(arr)
    printint
    printendl

    lea     arg1,   str_msg
    vmcall

    lea     arg1,   sizeof_msg
    vmcall
    push    sizeof(str)
    printint
    printendl

    pop     arg1,   lenof_msg
    vmcall
    push    lenof(str)
    printint
    printendl

    exit
