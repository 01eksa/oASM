; DEMO
; Rewrite exactly one byte
section .data
    line_1 = "You should see it twice\n"
    line_2 = "\nYou should see it once\n\n\0"


section .code
    push    line_1
    call    print:

    push    line_2
    push    '\0'
    writeb

    push    line_1
    call    print:
    
    exit

print:
	mov 	fr,		1	; vmcall printstr opcode
	pop 	arg1		; Pointer to string
	mov		arg2,	0	; Read until \0
	vmcall
	ret